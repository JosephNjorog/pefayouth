# Neon PostgreSQL Database
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# JWT Secret (minimum 32 characters, use a random string)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters

# M-Pesa Daraja API (Safaricom)
MPESA_CONSUMER_KEY=your_daraja_consumer_key
MPESA_CONSUMER_SECRET=your_daraja_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_daraja_passkey
MPESA_CALLBACK_URL=https://your-app.vercel.app/api/mpesa/callback
# Set to 'production' when going live
MPESA_ENV=sandbox
