{
  "name": "pefayouth",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "vercel dev",
    "dev:api": "npx tsx dev-server.ts",
    "dev:web": "cd apps/web && npm run dev",
